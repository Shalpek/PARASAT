rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function currentUserDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function orderDoc(orderId) {
      return /databases/$(database)/documents/orders/$(orderId);
    }

    function ownsOrder(orderId) {
      return signedIn()
        && exists(orderDoc(orderId))
        && get(orderDoc(orderId)).data.userId == request.auth.uid;
    }

    function isAdmin() {
      return signedIn()
        && exists(currentUserDoc())
        && get(currentUserDoc()).data.role == "admin";
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.role == "customer";

      allow read: if isOwner(uid) || isAdmin();

      allow update: if (
        isOwner(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role == resource.data.role
      ) || isAdmin();

      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.id == orderId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.paymentStatus == "pending"
        && request.resource.data.deliveryStatus == "not_created"
        && request.resource.data.orderStatus == "waiting_payment";

      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["paymentStatus", "deliveryStatus", "orderStatus", "updatedAt"])
        );

      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId == paymentId
        && request.resource.data.provider == "kaspi_mock";

      allow read: if isAdmin()
        || ownsOrder(paymentId)
        || (
          signedIn()
          && exists(/databases/$(database)/documents/payments/$(paymentId))
          && resource.data.userId == request.auth.uid
        );

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "paidAt", "updatedAt"])
        );

      allow delete: if isAdmin();
    }

    match /deliveries/{deliveryId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId == deliveryId
        && request.resource.data.provider == "yandex_delivery_mock";

      allow read: if isAdmin()
        || ownsOrder(deliveryId)
        || (
          signedIn()
          && exists(/databases/$(database)/documents/deliveries/$(deliveryId))
          && resource.data.userId == request.auth.uid
        );

      allow update: if isAdmin()
        || (
          signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(["status", "updatedAt"])
        );

      allow delete: if isAdmin();
    }
  }
}
